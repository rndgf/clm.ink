---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'clm.ink — Tattoo artist à Chambéry',
  description = 'Tatoueur spécialisé en geometric, realism et blackwork à Chambéry. Prise de rendez-vous, galerie de tatouages et informations pratiques.',
} = Astro.props;

// Relative path to site root for links (site is at domain root, no subdirectory)
const pathSegments = Astro.url.pathname.split('/').filter(Boolean);
const depth = pathSegments.length;
const relBase = depth === 0 ? './' : '../'.repeat(depth);

import '../styles/global.css';
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={Astro.site?.toString() ?? 'https://www.clm-ink.fr'} />
    <meta name="robots" content="index,follow" />
    <link rel="icon" type="image/svg+xml" href="/monogram.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <script type="application/ld+json">
      {JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'LocalBusiness',
        name: 'clm.ink',
        url: 'https://www.clm-ink.fr',
        image: 'https://www.clm-ink.fr/og-cover.jpg',
        description:
          'Tatoueur spécialisé en geometric, realism et blackwork à Chambéry, France.',
        address: {
          '@type': 'PostalAddress',
          addressLocality: 'Chambéry',
          addressCountry: 'FR',
        },
        sameAs: ['https://www.instagram.com/clm.ink/'],
      })}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600&family=Lato:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-neutral-800/80 bg-black/80 backdrop-blur sticky top-0 z-40">
      <div class="container-narrow flex items-center justify-between py-3">
        <a href={relBase} class="flex items-center gap-3">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-neutral-700 bg-neutral-950/80 overflow-hidden">
            <img
              src="/logo.png"
              alt="clm.ink"
              loading="lazy"
              class="h-full w-full object-contain"
            />
          </span>
          <span class="font-oswald font-semibold tracking-[0.25em] uppercase text-xs sm:text-sm">
            clm.ink
          </span>
        </a>
        <nav class="hidden sm:flex gap-6 text-xs uppercase tracking-[0.2em] text-neutral-400">
          <a href={`${relBase}#work`} class="hover:text-neutral-100 transition-colors">Portfolio</a>
          <a href={`${relBase}#infos`} class="hover:text-neutral-100 transition-colors">Infos</a>
          <a href={`${relBase}#contact`} class="hover:text-neutral-100 transition-colors">Contact</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-neutral-900 mt-16">
      <div
        class="container-narrow py-8 text-xs text-neutral-500 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3"
      >
        <div class="space-y-1">
          <p>
            © {new Date().getFullYear()} <a
              href={relBase}
              class="underline underline-offset-4 decoration-neutral-600 hover:decoration-neutral-300"
              >clm-ink.fr</a> — Tatoueur à Chambéry, Haute-Savoie, France.
          </p>
          <p class="text-[11px] text-neutral-600">
            <a
              href={`${relBase}studio-hygiene`}
              class="underline underline-offset-4 decoration-neutral-600 hover:decoration-neutral-300"
              >Informations & hygiène</a
            >
            <span class="mx-1">·</span>
            <a
              href={`${relBase}faq-tatouage`}
              class="underline underline-offset-4 decoration-neutral-600 hover:decoration-neutral-300"
              >FAQ tatouage</a
            >
            <span class="mx-1">·</span>
            <a
              href="https://www.instagram.com/clm.ink/"
              target="_blank"
              rel="noreferrer"
              class="underline underline-offset-4 decoration-neutral-600 hover:decoration-neutral-300"
              >Instagram</a
            >
          </p>
        </div>
        <div class="space-y-1 text-[11px] text-neutral-600">
          <p>
            Sponsor officiel
            <a
              href="https://www.instagram.com/hand_ink_"
              target="_blank"
              rel="noreferrer"
              class="underline underline-offset-4 decoration-neutral-600 hover:decoration-neutral-300"
            >
              @hand_ink_
            </a>
          </p>
          <p class="text-neutral-700">
            Site par
            <a
              href="https://www.renaudgouffe.fr"
              target="_blank"
              rel="noreferrer"
              class="underline underline-offset-4 decoration-neutral-700 hover:decoration-neutral-400"
            >
              rndgf
            </a>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

