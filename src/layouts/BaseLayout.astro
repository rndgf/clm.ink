---
interface Props {
  title?: string;
  description?: string;
  /** Full URL for Open Graph / Twitter Card image (defaults to site splash). */
  ogImage?: string;
}

const {
  title = 'clm.ink — Tattoo artist à Chambéry',
  description = 'Tatoueur spécialisé en geometric, realism et blackwork à Chambéry. Prise de rendez-vous, galerie de tatouages et informations pratiques.',
  ogImage,
} = Astro.props;

const site = Astro.site?.toString() ?? 'https://www.clm-ink.fr';
const pathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonical = new URL(pathname, site).href;
const imageUrl = ogImage ?? new URL('/images/splash.jpeg', site).href;

import '../styles/global.css';
---

<!doctype html>
<html lang="fr" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content="index,follow" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:site_name" content="clm.ink" />
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={imageUrl} />
    <link rel="icon" type="image/svg+xml" href="/monogram.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/logo.png" />
    <link rel="apple-touch-icon" href="/logo.png" />
    <script type="application/ld+json">
      {JSON.stringify({
        '@context': 'https://schema.org',
        '@type': 'LocalBusiness',
        name: 'clm.ink',
        url: 'https://www.clm-ink.fr',
        image: 'https://www.clm-ink.fr/og-cover.jpg',
        description:
          'Tatoueur spécialisé en geometric, realism et blackwork à Chambéry, France.',
        address: {
          '@type': 'PostalAddress',
          streetAddress: '4 rue Claude Martin',
          postalCode: '73000',
          addressLocality: 'Chambéry',
          addressCountry: 'FR',
        },
        sameAs: ['https://www.instagram.com/clm.ink/'],
      })}
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600&family=Lato:wght@300;400;500;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="min-h-screen flex flex-col">
    <header id="site-header" class="border-b border-neutral-800/80 bg-black/80 backdrop-blur sticky top-0 z-40">
      <div class="container-narrow flex items-center justify-between py-3">
        <a href="/" class="flex items-center gap-3">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-full border border-neutral-700 bg-neutral-950/80 overflow-hidden">
            <img
              src="/logo.png"
              alt=""
              loading="lazy"
              class="h-full w-full object-contain"
            />
          </span>
          <span class="font-oswald font-semibold tracking-[0.25em] uppercase text-xs sm:text-sm">
            clm.ink
          </span>
        </a>
        <button
          type="button"
          id="mobile-menu-btn"
          class="sm:hidden inline-flex h-10 w-10 items-center justify-center rounded-lg border border-neutral-600 text-neutral-300 hover:border-neutral-400 hover:text-neutral-100 transition-colors"
          aria-label="Ouvrir le menu"
          aria-expanded="false"
        >
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
        <nav id="main-nav" class="max-sm:hidden sm:flex max-sm:flex-col max-sm:absolute max-sm:top-full max-sm:left-0 max-sm:right-0 max-sm:bg-black max-sm:border-b max-sm:border-neutral-800 max-sm:py-4 max-sm:gap-4 max-sm:px-4 gap-6 text-xs uppercase tracking-[0.2em] text-neutral-400">
          <a href="/#work" class="hover:text-neutral-100 transition-colors">Portfolio</a>
          <a href="/#infos" class="hover:text-neutral-100 transition-colors">Infos</a>
          <a href="/#contact" class="hover:text-neutral-100 transition-colors">Contact</a>
        </nav>
      </div>
    </header>
    <script>
      (function () {
        const btn = document.getElementById("mobile-menu-btn");
        const nav = document.getElementById("main-nav");
        const header = document.getElementById("site-header");
        if (!btn || !nav) return;

        function setOpen(open) {
          if (open) {
            nav.classList.add("max-sm:!flex");
            btn.setAttribute("aria-expanded", "true");
            btn.setAttribute("aria-label", "Fermer le menu");
            header?.classList.add("mobile-menu-open");
          } else {
            nav.classList.remove("max-sm:!flex");
            btn.setAttribute("aria-expanded", "false");
            btn.setAttribute("aria-label", "Ouvrir le menu");
            header?.classList.remove("mobile-menu-open");
          }
        }

        btn.addEventListener("click", function () {
          setOpen(!nav.classList.contains("max-sm:!flex"));
        });

        nav.querySelectorAll("a").forEach(function (link) {
          link.addEventListener("click", function () {
            setOpen(false);
          });
        });
      })();
    </script>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-neutral-900 mt-16">
      <div
        class="container-narrow py-8 text-xs text-neutral-400 flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3"
      >
        <div class="space-y-1">
          <p>
            © {new Date().getFullYear()} <a
              href="/"
              class="underline underline-offset-4 decoration-neutral-500 hover:decoration-neutral-200 text-neutral-300"
              >clm-ink.fr</a> — Tatoueur à Chambéry, Haute-Savoie, France.
          </p>
          <p class="text-[11px] text-neutral-400">
            <a
              href="/studio-hygiene"
              class="underline underline-offset-4 decoration-neutral-500 hover:decoration-neutral-200 text-neutral-300"
              >Informations & hygiène</a
            >
            <span class="mx-1">·</span>
            <a
              href="/contact"
              class="underline underline-offset-4 decoration-neutral-500 hover:decoration-neutral-200 text-neutral-300"
              >Contact</a
            >
            <span class="mx-1">·</span>
            <a
              href="/faq-tatouage"
              class="underline underline-offset-4 decoration-neutral-500 hover:decoration-neutral-200 text-neutral-300"
              >FAQ tatouage</a
            >
            <span class="mx-1">·</span>
            <a
              href="https://www.instagram.com/clm.ink/"
              target="_blank"
              rel="noreferrer"
              class="underline underline-offset-4 decoration-neutral-500 hover:decoration-neutral-200 text-neutral-300"
              >Instagram</a
            >
          </p>
        </div>
        <div class="space-y-1 text-[11px] text-neutral-400">
          <p>
            Sponsor officiel
            <a
              href="https://www.instagram.com/hand_ink_"
              target="_blank"
              rel="noreferrer"
              class="underline underline-offset-4 decoration-neutral-500 hover:decoration-neutral-200 text-neutral-300"
            >
              @hand_ink_
            </a>
          </p>
          <p class="text-neutral-500">
            Site par
            <a
              href="https://www.renaudgouffe.fr"
              target="_blank"
              rel="noreferrer"
              class="underline underline-offset-4 decoration-neutral-500 hover:decoration-neutral-300 text-neutral-400"
            >
              rndgf
            </a>
          </p>
        </div>
      </div>
    </footer>
  </body>
</html>

