---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Gallery from '../components/Gallery.astro';
import InfoSection from '../components/InfoSection.astro';
---

<BaseLayout
  title="clm.ink — Tattoo artist geometric, realist & blackwork à Chambéry"
  description="Tatoueur clm.ink à Chambéry, spécialisé en geometric, realism et blackwork. Galerie de tatouages, informations pratiques et prise de contact."
>
  <Hero />
  <Gallery />
  <section class="border-b border-neutral-900 bg-black">
    <div class="container-narrow py-10 sm:py-14 space-y-6">
      <header class="space-y-2">
        <p class="text-xs uppercase tracking-[0.35em] text-neutral-500">
          Explorer le portfolio
        </p>
        <h2 class="text-xl sm:text-2xl font-semibold tracking-tight text-neutral-100">
          Galeries par style.
        </h2>
        <p class="text-sm text-neutral-400 max-w-2xl">
          Retrouvez une sélection de pièces classées par univers : géométrique, réalisme noir et gris
          ou blackwork graphique. Idéal pour voir comment chaque style vit sur la peau.
        </p>
      </header>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 text-sm">
        <a
          href="/geometric"
          class="group rounded-2xl border border-neutral-800 bg-neutral-950/60 px-5 py-4 flex flex-col gap-2 hover:border-neutral-200 hover:bg-neutral-900/80 transition-colors"
        >
          <h3 class="text-sm font-medium text-neutral-50">Geometric</h3>
          <p class="text-xs text-neutral-400">
            Lignes fines, mandalas, motifs abstraits et compositions graphiques en noir et gris.
          </p>
        </a>

        <a
          href="/realism"
          class="group rounded-2xl border border-neutral-800 bg-neutral-950/60 px-5 py-4 flex flex-col gap-2 hover:border-neutral-200 hover:bg-neutral-900/80 transition-colors"
        >
          <h3 class="text-sm font-medium text-neutral-50">Realism</h3>
          <p class="text-xs text-neutral-400">
            Portraits, animaux et pièces réalistes en noir et gris, centrées sur les contrastes.
          </p>
        </a>

        <a
          href="/blackwork"
          class="group rounded-2xl border border-neutral-800 bg-neutral-950/60 px-5 py-4 flex flex-col gap-2 hover:border-neutral-200 hover:bg-neutral-900/80 transition-colors"
        >
          <h3 class="text-sm font-medium text-neutral-50">Blackwork</h3>
          <p class="text-xs text-neutral-400">
            Aplats noirs, textures et compositions fortes pour des projets graphiques impactants.
          </p>
        </a>
      </div>
    </div>
  </section>
  <InfoSection />
</BaseLayout>

