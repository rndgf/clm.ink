---
import BaseLayout from "../layouts/BaseLayout.astro";
import PortfolioInstagramCta from "../components/PortfolioInstagramCta.astro";
---

<BaseLayout
  title="Portfolio tatouage à Chambéry — clm.ink | Geometric, réalisme, blackwork"
  description="Galerie de tatouages réalisés par clm.ink à Chambéry. Explorez le portfolio par style : geometric, réalisme noir et gris, blackwork."
>
  <section class="bg-gradient-to-b from-black via-black to-neutral-950">
    <div class="container-narrow py-14 sm:py-20 space-y-10 sm:space-y-12">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-xs text-neutral-500 hover:text-neutral-300 transition-colors"
        aria-label="Retour à l'accueil"
      >
        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
        Retour
      </a>
      <header class="space-y-3">
        <p class="text-xs uppercase tracking-[0.35em] text-neutral-500">
          Galerie
        </p>
        <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">
          Portfolio.
        </h1>
        <p class="text-sm sm:text-base text-neutral-300 max-w-2xl">
          Sélection de pièces réalisées au studio à Chambéry. Explorez par
          style : geometric, réalisme noir et gris, blackwork.
        </p>
      </header>

      <nav
        class="grid gap-6 sm:grid-cols-3"
        aria-label="Exploration du portfolio par style"
      >
        <a
          href="/geometric"
          class="group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/60 px-6 py-6 sm:p-8 flex flex-col gap-2 hover:border-neutral-200 hover:bg-neutral-900/80 transition-colors focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:ring-offset-2 focus:ring-offset-black"
        >
          <div
            class="pointer-events-none absolute inset-0 opacity-[0.15] group-hover:opacity-[0.25] transition-opacity"
            aria-hidden="true"
          >
            <img
              src="/geometric.png"
              alt=""
              loading="lazy"
              class="h-full w-full object-cover grayscale scale-150 -translate-x-4"
            />
          </div>
          <div class="relative">
            <h2 class="text-xl sm:text-2xl font-semibold tracking-tight text-neutral-100 group-hover:text-neutral-50 transition-colors">
              Geometric
            </h2>
            <p class="mt-3 text-sm text-neutral-400">
              Lignes fines, mandalas, motifs abstraits et compositions en noir
              et gris.
            </p>
            <span
              class="mt-4 inline-block text-xs uppercase tracking-[0.2em] text-neutral-400 group-hover:text-neutral-300 transition-colors"
            >
              Voir la galerie →
            </span>
          </div>
        </a>
        <a
          href="/realism"
          class="group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/60 px-6 py-6 sm:p-8 flex flex-col gap-2 hover:border-neutral-200 hover:bg-neutral-900/80 transition-colors focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:ring-offset-2 focus:ring-offset-black"
        >
          <div
            class="pointer-events-none absolute inset-0 opacity-[0.15] group-hover:opacity-[0.25] transition-opacity"
            aria-hidden="true"
          >
            <img
              src="/realism.png"
              alt=""
              loading="lazy"
              class="h-full w-full object-cover grayscale scale-150 translate-x-6"
            />
          </div>
          <div class="relative">
            <h2 class="text-xl sm:text-2xl font-semibold tracking-tight text-neutral-100 group-hover:text-neutral-50 transition-colors">
              Realism
            </h2>
            <p class="mt-3 text-sm text-neutral-400">
              Portraits, animaux, crânes et compositions en noir et gris.
            </p>
            <span
              class="mt-4 inline-block text-xs uppercase tracking-[0.2em] text-neutral-400 group-hover:text-neutral-300 transition-colors"
            >
              Voir la galerie →
            </span>
          </div>
        </a>
        <a
          href="/blackwork"
          class="group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/60 px-6 py-6 sm:p-8 flex flex-col gap-2 hover:border-neutral-200 hover:bg-neutral-900/80 transition-colors focus:outline-none focus:ring-2 focus:ring-neutral-500 focus:ring-offset-2 focus:ring-offset-black"
        >
          <div
            class="pointer-events-none absolute inset-0 opacity-[0.15] group-hover:opacity-[0.25] transition-opacity"
            aria-hidden="true"
          >
            <img
              src="/blackwork.png"
              alt=""
              loading="lazy"
              class="h-full w-full object-cover grayscale scale-150"
            />
          </div>
          <div class="relative">
            <h2 class="text-xl sm:text-2xl font-semibold tracking-tight text-neutral-100 group-hover:text-neutral-50 transition-colors">
              Blackwork
            </h2>
            <p class="mt-3 text-sm text-neutral-400">
              Aplats noirs, formes graphiques et contrastes marqués.
            </p>
            <span
              class="mt-4 inline-block text-xs uppercase tracking-[0.2em] text-neutral-400 group-hover:text-neutral-300 transition-colors"
            >
              Voir la galerie →
            </span>
          </div>
        </a>
      </nav>

      <PortfolioInstagramCta />
    </div>
  </section>
</BaseLayout>
