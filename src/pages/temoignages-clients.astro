---
import BaseLayout from "../layouts/BaseLayout.astro";
import testimonialsData from "../data/testimonials.json";

const MONTHS: Record<string, number> = {
  janvier: 1,
  février: 2,
  mars: 3,
  avril: 4,
  mai: 5,
  juin: 6,
  juillet: 7,
  août: 8,
  septembre: 9,
  octobre: 10,
  novembre: 11,
  décembre: 12,
};

function parseDateKey(dateStr: string): number {
  if (!dateStr || !dateStr.trim()) return 0;
  const parts = dateStr.trim().toLowerCase().split(/\s+/);
  const monthStr = parts[0];
  const year = parseInt(parts[1], 10);
  const month = MONTHS[monthStr] ?? 0;
  if (!year || !month) return 0;
  return year * 12 + month;
}

const testimonialsRaw = testimonialsData as {
  author: string;
  text: string;
  date: string;
}[];
const testimonials = [...testimonialsRaw].sort(
  (a, b) => parseDateKey(b.date) - parseDateKey(a.date),
);
const testimonialsJson = JSON.stringify(testimonialsRaw).replace(
  /</g,
  "\\u003c",
);

function getInitials(author: string): string {
  const parts = author.trim().split(/\s+/);
  const letters = parts
    .map((p) => p.replace(/[^a-zA-Z]/g, "").charAt(0))
    .filter(Boolean)
    .join("")
    .toUpperCase();
  return letters.slice(0, 2) || "—";
}
---

<script is:inline define:vars={{ testimonialsJson }}>
  window.__TESTIMONIALS__ = JSON.parse(testimonialsJson);
</script>

<BaseLayout
  title="Avis et témoignages clients — tatoueur à Chambéry | clm.ink"
  description="Avis Google et témoignages clients sur clm.ink à Chambéry : expérience au studio, hygiène, écoute et rendu des pièces geometric, réalisme et blackwork."
>
  <section class="bg-black border-t border-neutral-900">
    <div class="container-narrow py-10 sm:py-12 space-y-6">
      <a
        href="/"
        class="inline-flex items-center gap-2 text-xs text-neutral-500 hover:text-neutral-300 transition-colors"
        aria-label="Retour à l'accueil"
      >
        <i class="fa-solid fa-arrow-left" aria-hidden="true"></i>
        Retour
      </a>
      <header class="space-y-3">
        <p class="text-xs uppercase tracking-[0.35em] text-neutral-500">
          Témoignages
        </p>
        <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight">
          Ce que mes clients disent.
        </h1>
        <p class="text-sm sm:text-base text-neutral-300 max-w-2xl">
          Cette page liste quelques-uns des avis laissés par mes clients après
          leur passage dans mon salon de tatouage à Chambéry.
        </p>
      </header>

      <div class="testimonials-grid grid gap-4 sm:grid-cols-2">
        {
          testimonials.map((item) => (
            <blockquote class="rounded-xl border border-neutral-800 bg-neutral-950/60 px-4 py-4 sm:px-5 sm:py-5 space-y-3">
              <div class="flex items-center justify-between gap-3">
                <div class="flex items-center gap-3 min-w-0">
                  <div
                    class="w-10 h-10 sm:w-11 sm:h-11 rounded-full bg-neutral-600 flex items-center justify-center shrink-0 text-sm font-semibold text-neutral-100"
                    aria-hidden="true"
                  >
                    {getInitials(item.author)}
                  </div>
                  <p class="text-sm font-medium text-neutral-100 not-italic truncate">
                    {item.author}
                  </p>
                </div>
                <div
                  class="flex gap-0.5 text-amber-400/90 shrink-0"
                  aria-hidden="true"
                >
                  {[1, 2, 3, 4, 5].map(() => (
                    <svg
                      class="w-4 h-4 shrink-0"
                      aria-hidden="true"
                      viewBox="0 0 20 20"
                      fill="currentColor"
                    >
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  ))}
                </div>
              </div>
              <p class="text-sm sm:text-base text-neutral-200 leading-relaxed">
                {item.text}
              </p>
              {item.date && (
                <p class="text-xs text-neutral-500 pt-1">{item.date}</p>
              )}
            </blockquote>
          ))
        }
      </div>

      <p class="text-xs text-neutral-500 pt-4">
        <a
          href="https://www.google.com/search?sa=X&q=CLM.ink+Avis&tbm=lcl"
          target="_blank"
          rel="noreferrer noopener"
          class="underline underline-offset-4 decoration-neutral-500 hover:decoration-neutral-400 text-neutral-400"
        >
          <span aria-hidden="true">→</span>
          Voir tous les avis sur Google
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
