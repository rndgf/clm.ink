---
import testimonialsData from "../data/testimonials.json";

const allTestimonials = testimonialsData as { author: string; text: string }[];
const testimonials = allTestimonials.slice(0, 10);
const testimonialsJson = JSON.stringify(allTestimonials).replace(/</g, "\\u003c");
---
<script is:inline define:vars={{ testimonialsJson }}>
  window.__TESTIMONIALS__ = JSON.parse(testimonialsJson);
</script>

<section id="avis-clients" class="border-t border-neutral-900 bg-black">
  <div class="container-narrow py-8 sm:py-10 space-y-5">
    <header
      class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4"
    >
      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-neutral-500">
          Témoignages
        </p>
        <h2 class="mt-2 text-2xl sm:text-3xl font-semibold tracking-tight">
          Ce que mes clients disent.
        </h2>
      </div>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <a
          href="/temoignages-clients"
          class="text-sm text-neutral-400 hover:text-neutral-200 transition-colors underline underline-offset-4 decoration-neutral-600 hover:decoration-neutral-400"
        >
          Tous les témoignages →
        </a>
        <a
          href="https://www.google.com/search?sa=X&q=CLM.ink+Avis&tbm=lcl"
          target="_blank"
          rel="noreferrer noopener"
          class="text-sm text-neutral-400 hover:text-neutral-200 transition-colors underline underline-offset-4 decoration-neutral-600 hover:decoration-neutral-400"
        >
          Avis sur Google →
        </a>
      </div>
    </header>

    <div
      class="relative testimonials-slider-wrapper -mx-4 sm:-mx-6 lg:-mx-8 w-[calc(100%+2rem)] sm:w-[calc(100%+3rem)] lg:w-[calc(100%+4rem)]"
      data-auto-play="true"
    >
      <button
        type="button"
        class="testimonials-prev max-sm:hidden inline-flex h-9 w-9 items-center justify-center rounded-full border border-neutral-600 bg-black/40 text-sm text-neutral-100 hover:border-neutral-200 hover:bg-neutral-800/90 hover:text-neutral-50 transition-colors absolute left-2 top-1/2 -translate-y-1/2 z-10"
        aria-label="Avis précédent"
      >
        ‹
      </button>
      <button
        type="button"
        class="testimonials-next max-sm:hidden inline-flex h-9 w-9 items-center justify-center rounded-full border border-neutral-600 bg-black/40 text-sm text-neutral-100 hover:border-neutral-200 hover:bg-neutral-800/90 hover:text-neutral-50 transition-colors absolute right-2 top-1/2 -translate-y-1/2 z-10"
        aria-label="Avis suivant"
      >
        ›
      </button>

      <div class="overflow-hidden">
        <div
          class="testimonials-track flex transition-transform ease-out duration-500"
          data-page-count={testimonials.length}
        >
          {
            testimonials.map((item, index) => (
              <div
                class="min-w-full px-2 sm:px-4 flex justify-center"
                data-page={index}
              >
                <blockquote class="w-full max-w-2xl rounded-xl border border-neutral-800 bg-neutral-950/60 px-4 py-4 sm:px-6 sm:py-5">
                  <div
                    class="flex gap-0.5 text-neutral-600 mb-2"
                    aria-hidden="true"
                  >
                    {[1, 2, 3, 4, 5].map(() => (
                      <svg
                        class="w-3 h-3 shrink-0"
                        aria-hidden="true"
                        viewBox="0 0 20 20"
                        fill="currentColor"
                      >
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                      </svg>
                    ))}
                  </div>
                  <p class="text-sm text-neutral-200 leading-relaxed">
                    « {item.text} »
                  </p>
                  <cite class="mt-2 not-italic text-xs text-neutral-500">
                    — {item.author}
                  </cite>
                </blockquote>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
