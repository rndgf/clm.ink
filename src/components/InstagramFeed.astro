---
const maxPosts = 6;
---

<section id="instagram" class="border-b border-neutral-900 bg-black">
  <div class="container-narrow py-14 sm:py-20 space-y-8">
    <header class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-neutral-500">
          Derniers posts
        </p>
        <h2 class="mt-2 text-2xl sm:text-3xl font-semibold tracking-tight">Instagram</h2>
      </div>
      <p class="text-sm text-neutral-400 max-w-md">
        Flux automatique des derniers posts Instagram. Configurez vos identifiants dans les variables
        d&apos;environnement pour activer la récupération en direct.
      </p>
    </header>

    <div
      id="instagram-grid"
      class="grid grid-cols-2 sm:grid-cols-3 gap-3 sm:gap-4"
      data-max-posts={maxPosts}
    >
      <div class="col-span-2 sm:col-span-3 border border-dashed border-neutral-800/80 rounded-2xl p-6 text-sm text-neutral-400 flex flex-col gap-3">
        <p>
          Le flux Instagram se mettra ici automatiquement dès que les identifiants seront configurés.
        </p>
        <p class="text-xs text-neutral-500">
          Ajoutez les variables
          <code class="px-1 py-0.5 rounded bg-neutral-900/80 border border-neutral-800 text-[11px]">
            PUBLIC_INSTAGRAM_ACCESS_TOKEN
          </code>
          et
          <code class="px-1 py-0.5 rounded bg-neutral-900/80 border border-neutral-800 text-[11px]">
            PUBLIC_INSTAGRAM_USER_ID
          </code>
          à votre fichier d&apos;environnement, puis rebuild le site.
        </p>
        <a
          href="https://www.instagram.com/clm.ink/"
          target="_blank"
          rel="noreferrer"
          class="inline-flex w-fit items-center gap-2 rounded-full border border-neutral-800 px-4 py-1.5 text-[11px] uppercase tracking-[0.24em] text-neutral-300 hover:border-neutral-200 hover:text-neutral-100 transition-colors"
        >
          Ouvrir le profil
        </a>
      </div>
    </div>
  </div>

  <script>
    const accessToken = import.meta.env.PUBLIC_INSTAGRAM_ACCESS_TOKEN;
    const userId = import.meta.env.PUBLIC_INSTAGRAM_USER_ID;

    async function loadInstagram() {
      if (!accessToken || !userId) {
        return;
      }

      const grid = document.getElementById('instagram-grid');
      if (!grid) return;

      const max = Number(grid.dataset.maxPosts ?? 6);

      try {
        const response = await fetch(
          `https://graph.instagram.com/${userId}/media?fields=id,caption,media_url,permalink,media_type,thumbnail_url,timestamp&access_token=${accessToken}&limit=${max}`,
        );

        if (!response.ok) {
          console.error('Failed to fetch Instagram media');
          return;
        }

        const data = await response.json();
        if (!Array.isArray(data.data)) {
          return;
        }

        grid.innerHTML = '';

        for (const item of data.data) {
          if (!item.media_url) continue;

          const col = document.createElement('a');
          col.href = item.permalink;
          col.target = '_blank';
          col.rel = 'noreferrer';
          col.className =
            'group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/80';

          const isVideo = item.media_type === 'VIDEO';
          const imageUrl = isVideo && item.thumbnail_url ? item.thumbnail_url : item.media_url;

          col.innerHTML = `
            <div class="aspect-square w-full bg-neutral-900">
              <img
                src="${imageUrl}"
                alt="${(item.caption || 'Tattoo by clm.ink').replace(/"/g, '&quot;')}"
                loading="lazy"
                class="h-full w-full object-cover filter grayscale group-hover:grayscale-0 transition duration-500"
              />
            </div>
            <div class="absolute inset-0 pointer-events-none bg-gradient-to-t from-black/60 via-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
            <div class="absolute bottom-0 left-0 right-0 p-3 text-[11px] uppercase tracking-[0.18em] text-neutral-100 flex items-center justify-between">
              <span>Instagram</span>
              <span class="text-neutral-400">${
                new Date(item.timestamp).toLocaleDateString('fr-FR', {
                  year: '2-digit',
                  month: '2-digit',
                  day: '2-digit',
                }) ?? ''
              }</span>
            </div>
          `;

          grid.appendChild(col);
        }
      } catch (error) {
        console.error('Error while loading Instagram feed', error);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', loadInstagram);
    } else {
      loadInstagram();
    }
  </script>
</section>

