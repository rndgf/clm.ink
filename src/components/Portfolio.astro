---
interface Props {
  title?: string;
  kicker?: string;
  description?: string;
  /** When set, load only images from this gallery subfolder (geometric, realism, blackwork). */
  folder?: "geometric" | "realism" | "blackwork";
  /** When true, show 20 random images from all folders and auto-advance the slider. */
  autoPlay?: boolean;
}

const {
  title = "Portfolio.",
  kicker = "Sélection de pièces",
  description = "Un aperçu de mon travail réalisé en studio : grandes pièces, micro-tattoos et projets sur-mesure. Images en noir et blanc, orientées geometric, realism et blackwork.",
  folder,
  autoPlay = false,
} = Astro.props as Props;

// Load image paths at build time (Node fs/path).
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const { readdirSync }: any = await (globalThis as any)
  .eval("import('node:fs')")
  .then((m: any) => m);
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const pathMod: any = await (globalThis as any)
  .eval("import('node:path')")
  .then((m: any) => m);

const galleryBase = pathMod.resolve("public/images/gallery");
const imageExt = /\.(jpe?g|png|webp)$/i;

type ImageEntry = { name: string; subfolder: string };

function listImagesInDir(dirPath: string, subfolder: string): ImageEntry[] {
  try {
    const entries = readdirSync(dirPath, { withFileTypes: true }) as {
      name: string;
      isFile: () => boolean;
    }[];
    return entries
      .filter((e) => e.isFile() && imageExt.test(e.name))
      .map((e) => ({ name: e.name, subfolder }));
  } catch {
    return [];
  }
}

function shuffle<T>(arr: T[]): T[] {
  const out = [...arr];
  for (let i = out.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [out[i], out[j]] = [out[j], out[i]];
  }
  return out;
}

let rawImages: ImageEntry[];

if (folder) {
  rawImages = listImagesInDir(pathMod.join(galleryBase, folder), folder);
  rawImages.sort((a, b) => a.name.localeCompare(b.name));
} else {
  const subfolders = ["geometric", "realism", "blackwork"] as const;
  rawImages = subfolders.flatMap((sub) =>
    listImagesInDir(pathMod.join(galleryBase, sub), sub),
  );
  rawImages = shuffle(rawImages).slice(0, 15);
}

const pieces = rawImages.map((entry, index) => ({
  id: `img-${index + 1}`,
  src: `/images/gallery/${entry.subfolder}/${entry.name}`,
  title: `Tatouage clm.ink #${index + 1}`,
}));

const PER_SLIDE = 3;
const PER_PAGE_THEME = 20;

const groups: (typeof pieces)[] = [];
const themePageGroups: (typeof pieces)[] = [];

if (folder) {
  for (let i = 0; i < pieces.length; i += PER_PAGE_THEME) {
    themePageGroups.push(pieces.slice(i, i + PER_PAGE_THEME));
  }
} else {
  for (let i = 0; i < pieces.length; i += PER_SLIDE) {
    groups.push(pieces.slice(i, i + PER_SLIDE));
  }
}

const totalThemePages = themePageGroups.length;
---

<section id="work" class="border-b border-neutral-900 bg-black">
  <div class="container-narrow py-14 sm:py-20 space-y-8">
    <header
      class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4"
    >
      <div>
        <p class="text-xs uppercase tracking-[0.35em] text-neutral-500">
          {kicker}
        </p>
        <h2 class="mt-2 text-2xl sm:text-3xl font-semibold tracking-tight">
          {title}
        </h2>
      </div>
      <p class="text-sm text-neutral-400 max-w-md">
        {description}
      </p>
    </header>

    {
      folder ? (
        <div
          class="gallery-pagination-wrapper"
          data-total-pages={totalThemePages}
        >
          {themePageGroups.map((pagePieces, pageIndex) => (
            <div
              class={`gallery-page ${pageIndex === 0 ? "block" : "hidden"}`}
              data-page={pageIndex}
            >
              <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5">
                {pagePieces.map((piece) => (
                  <button
                    type="button"
                    data-gallery-image
                    class="group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/80 focus:outline-none focus:ring-2 focus:ring-neutral-400/60"
                  >
                    <div class="aspect-[4/5] w-full bg-neutral-900">
                      <img
                        src={piece.src}
                        alt={piece.title}
                        loading="lazy"
                        decoding="async"
                        class="h-full w-full object-cover filter grayscale group-hover:grayscale-0 transition duration-500"
                      />
                    </div>
                  </button>
                ))}
              </div>
            </div>
          ))}
          {totalThemePages > 1 && (
            <nav
              class="mt-8 flex items-center justify-center gap-4"
              aria-label="Pagination galerie"
            >
              <button
                type="button"
                class="gallery-pagination-prev inline-flex items-center justify-center rounded-full border border-neutral-600 bg-black/60 px-4 py-2 text-xs uppercase tracking-wider text-neutral-300 hover:border-neutral-200 hover:text-neutral-100 disabled:opacity-40 disabled:pointer-events-none transition-colors"
                aria-label="Page précédente"
              >
                ‹ Précédent
              </button>
              <span class="gallery-pagination-info text-xs text-neutral-500 min-w-[6rem] text-center">
                Page{" "}
                <span class="gallery-pagination-current font-medium text-neutral-300">
                  1
                </span>{" "}
                /{" "}
                <span class="gallery-pagination-total">{totalThemePages}</span>
              </span>
              <button
                type="button"
                class="gallery-pagination-next inline-flex items-center justify-center rounded-full border border-neutral-600 bg-black/60 px-4 py-2 text-xs uppercase tracking-wider text-neutral-300 hover:border-neutral-200 hover:text-neutral-100 disabled:opacity-40 disabled:pointer-events-none transition-colors"
                aria-label="Page suivante"
              >
                Suivant ›
              </button>
            </nav>
          )}
        </div>
      ) : (
        <div
          class="relative gallery-slider-wrapper"
          data-auto-play={autoPlay ? "true" : undefined}
        >
          <button
            type="button"
            class="gallery-prev max-sm:hidden inline-flex h-9 w-9 items-center justify-center rounded-full border border-neutral-600 bg-black/40 text-sm text-neutral-100 hover:border-neutral-200 hover:bg-neutral-800/90 hover:text-neutral-50 transition-colors absolute left-2 top-1/2 -translate-y-1/2 z-10"
            aria-label="Pièces précédentes"
          >
            ‹
          </button>
          <button
            type="button"
            class="gallery-next max-sm:hidden inline-flex h-9 w-9 items-center justify-center rounded-full border border-neutral-600 bg-black/40 text-sm text-neutral-100 hover:border-neutral-200 hover:bg-neutral-800/90 hover:text-neutral-50 transition-colors absolute right-2 top-1/2 -translate-y-1/2 z-10"
            aria-label="Pièces suivantes"
          >
            ›
          </button>

          <div class="overflow-hidden">
            <div
              class={`gallery-track flex transition-transform ease-out ${autoPlay ? "duration-700" : "duration-500"}`}
              data-page-count={groups.length}
            >
              {groups.map((group, index) => (
                <div
                  class="min-w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5"
                  data-page={index}
                >
                  {group.map((piece, pieceIndex) => (
                    <button
                      type="button"
                      data-gallery-image
                      class={
                        "group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/80 focus:outline-none focus:ring-2 focus:ring-neutral-400/60" +
                        (pieceIndex > 0 ? " hidden sm:block" : "")
                      }
                    >
                      <div class="aspect-[4/5] w-full bg-neutral-900">
                        <img
                          src={piece.src}
                          alt={piece.title}
                          loading="lazy"
                          decoding="async"
                          class="h-full w-full object-cover filter grayscale group-hover:grayscale-0 transition duration-500"
                        />
                      </div>
                    </button>
                  ))}
                </div>
              ))}
            </div>
          </div>
        </div>
      )
    }

    <p class="text-xs text-neutral-500">
      Les projets visibles ici ne représentent qu&apos;une partie des pièces
      réalisées. Retrouvez plus de contenu sur instagram :
      <a
        href="https://www.instagram.com/clm.ink/"
        target="_blank"
        rel="noreferrer"
        class="ml-1 underline underline-offset-4 decoration-neutral-500 hover:decoration-neutral-200"
      >
        @clm.ink
      </a>
      .
    </p>
  </div>
</section>

<div
  id="gallery-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 px-4"
>
  <button
    type="button"
    class="absolute inset-0 w-full h-full cursor-default"
    data-gallery-close
    aria-label="Fermer l'image"></button>
  <div
    class="relative max-w-3xl w-full max-h-[90vh] flex flex-col items-center"
  >
    <div class="absolute -top-10 right-0 flex justify-end shrink-0">
      <button
        type="button"
        class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-neutral-600 text-xs text-neutral-200 hover:border-neutral-300 hover:text-neutral-50 bg-black/60"
        data-gallery-close
        aria-label="Fermer"
      >
        ✕
      </button>
    </div>
    <div
      class="w-max max-w-full max-h-[85vh] rounded-2xl border border-neutral-800 bg-neutral-950/80 overflow-hidden"
    >
      <img
        id="gallery-modal-image"
        src=""
        alt=""
        loading="lazy"
        class="max-h-[85vh] max-w-full w-auto h-auto object-contain block"
      />
    </div>
  </div>
</div>

<script>
  function initGallerySlider() {
    const track = document.querySelector<HTMLDivElement>(".gallery-track");
    const prev = document.querySelector<HTMLButtonElement>(".gallery-prev");
    const next = document.querySelector<HTMLButtonElement>(".gallery-next");
    const wrapper = track?.closest(".gallery-slider-wrapper");

    if (!track || !prev || !next) return;

    const pageCount = Number(track.dataset.pageCount ?? 1);
    let current = 0;
    let touchStartX: number | null = null;
    let autoplayInterval: ReturnType<typeof setInterval> | null = null;

    function update() {
      track!.style.transform = `translateX(-${current * 100}%)`;
    }

    function startAutoplay() {
      if (
        autoplayInterval ||
        !wrapper ||
        wrapper.getAttribute("data-auto-play") !== "true"
      )
        return;
      autoplayInterval = setInterval(() => {
        current = (current + 1) % pageCount;
        update();
      }, 4000);
    }

    function stopAutoplay() {
      if (autoplayInterval) {
        clearInterval(autoplayInterval);
        autoplayInterval = null;
      }
    }

    prev.addEventListener("click", () => {
      current = (current - 1 + pageCount) % pageCount;
      update();
    });

    next.addEventListener("click", () => {
      current = (current + 1) % pageCount;
      update();
    });

    track.addEventListener("touchstart", (event) => {
      if (event.touches.length !== 1) return;
      touchStartX = event.touches[0].clientX;
    });

    track.addEventListener("touchend", (event) => {
      if (touchStartX === null) return;
      const touchEndX = event.changedTouches[0].clientX;
      const deltaX = touchEndX - touchStartX;
      const threshold = 40;

      if (Math.abs(deltaX) > threshold) {
        if (deltaX < 0) {
          current = (current + 1) % pageCount;
        } else {
          current = (current - 1 + pageCount) % pageCount;
        }
        update();
      }

      touchStartX = null;
    });

    if (wrapper?.getAttribute("data-auto-play") === "true") {
      wrapper.addEventListener("mouseenter", stopAutoplay);
      wrapper.addEventListener("mouseleave", startAutoplay);
      startAutoplay();
    }

    update();
  }

  function initGalleryModal() {
    const modal = document.getElementById(
      "gallery-modal",
    ) as HTMLDivElement | null;
    const modalImg = document.getElementById(
      "gallery-modal-image",
    ) as HTMLImageElement | null;
    const imageButtons = document.querySelectorAll<HTMLButtonElement>(
      "[data-gallery-image]",
    );
    const closeButtons = document.querySelectorAll<HTMLButtonElement>(
      "[data-gallery-close]",
    );

    if (!modal || !modalImg || imageButtons.length === 0) return;

    const images: { src: string; alt: string }[] = [];
    imageButtons.forEach((btn, index) => {
      const img = btn.querySelector("img");
      if (!img) return;
      images.push({ src: img.src, alt: img.alt || "" });
      btn.dataset.index = String(images.length - 1);
    });

    let currentIndex = 0;

    function showImage(index: number) {
      if (!modal || !modalImg || images.length === 0) return;
      const boundedIndex =
        ((index % images.length) + images.length) % images.length;
      const { src, alt } = images[boundedIndex];
      modalImg.src = src;
      modalImg.alt = alt;
      currentIndex = boundedIndex;
    }

    function openModal(index: number) {
      if (!modal) return;
      showImage(index);
      modal.classList.remove("hidden");
      modal.classList.add("flex");
    }

    function closeModal() {
      if (!modal || !modalImg) return;
      modal.classList.add("hidden");
      modal.classList.remove("flex");
      modalImg.src = "";
      modalImg.alt = "";
    }

    imageButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const rawIndex = btn.dataset.index;
        if (!rawIndex) return;
        const index = Number(rawIndex);
        if (Number.isNaN(index)) return;
        openModal(index);
      });
    });

    closeButtons.forEach((btn) => {
      btn.addEventListener("click", closeModal);
    });

    document.addEventListener("keydown", (event) => {
      if (!modal || modal.classList.contains("hidden")) return;
      if (event.key === "Escape") {
        closeModal();
      } else if (event.key === "ArrowRight") {
        showImage(currentIndex + 1);
      } else if (event.key === "ArrowLeft") {
        showImage(currentIndex - 1);
      }
    });

    let touchStartX: number | null = null;

    modal.addEventListener("touchstart", (event) => {
      if (event.touches.length !== 1) return;
      touchStartX = event.touches[0].clientX;
    });

    modal.addEventListener("touchend", (event) => {
      if (touchStartX === null) return;
      const touchEndX = event.changedTouches[0].clientX;
      const deltaX = touchEndX - touchStartX;
      const threshold = 40;

      if (Math.abs(deltaX) > threshold) {
        if (deltaX < 0) {
          showImage(currentIndex + 1);
        } else {
          showImage(currentIndex - 1);
        }
      }

      touchStartX = null;
    });
  }

  function initGalleryPagination() {
    const wrapper = document.querySelector<HTMLDivElement>(
      ".gallery-pagination-wrapper",
    );
    if (!wrapper) return;

    const pages = wrapper.querySelectorAll<HTMLDivElement>(".gallery-page");
    const prevBtn = wrapper.querySelector<HTMLButtonElement>(
      ".gallery-pagination-prev",
    );
    const nextBtn = wrapper.querySelector<HTMLButtonElement>(
      ".gallery-pagination-next",
    );
    const currentEl = wrapper.querySelector<HTMLSpanElement>(
      ".gallery-pagination-current",
    );
    const totalPages = Number(wrapper.dataset.totalPages ?? 1);

    if (pages.length === 0 || totalPages <= 1) return;

    let current = 0;

    function update() {
      pages.forEach((page, i) => {
        page.classList.toggle("hidden", i !== current);
        page.classList.toggle("block", i === current);
      });
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current === totalPages - 1;
      if (currentEl) currentEl.textContent = String(current + 1);
    }

    prevBtn?.addEventListener("click", () => {
      if (current > 0) {
        current--;
        update();
      }
    });

    nextBtn?.addEventListener("click", () => {
      if (current < totalPages - 1) {
        current++;
        update();
      }
    });

    update();
  }

  function initGallery() {
    initGallerySlider();
    initGalleryPagination();
    initGalleryModal();
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initGallery);
  } else {
    initGallery();
  }
</script>
