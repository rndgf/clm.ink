---
import PortfolioInstagramCta from "./PortfolioInstagramCta.astro";

interface Props {
  title?: string;
  kicker?: string;
  description?: string;
  /** When set, load only images from this gallery subfolder (geometric, realism, blackwork). */
  folder?: "geometric" | "realism" | "blackwork";
  /** When true, show 20 random images from all folders and auto-advance the slider. */
  autoPlay?: boolean;
  /** When true and folder is set, only render the gallery (no header). For thematic gallery pages. */
  hideHeader?: boolean;
}

const {
  title = "Portfolio.",
  kicker = "Sélection de pièces",
  description = "Un aperçu de mon travail réalisé au salon de tatouage à Chambéry : grandes pièces, micro-tattoos et projets sur-mesure. Images en noir et blanc, orientées geometric, realism et blackwork.",
  folder,
  autoPlay = false,
  hideHeader = false,
} = Astro.props as Props;

// Load image paths at build time (Node fs/path).
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const { readdirSync }: any = await (globalThis as any)
  .eval("import('node:fs')")
  .then((m: any) => m);
// eslint-disable-next-line @typescript-eslint/no-explicit-any
const pathMod: any = await (globalThis as any)
  .eval("import('node:path')")
  .then((m: any) => m);

const galleryBase = pathMod.resolve("public/images/gallery");
const imageExt = /\.(jpe?g|png|webp)$/i;

type ImageEntry = { name: string; subfolder: string };

function listImagesInDir(dirPath: string, subfolder: string): ImageEntry[] {
  try {
    const entries = readdirSync(dirPath, { withFileTypes: true }) as {
      name: string;
      isFile: () => boolean;
    }[];
    return entries
      .filter((e) => e.isFile() && imageExt.test(e.name))
      .map((e) => ({ name: e.name, subfolder }));
  } catch {
    return [];
  }
}

function shuffle<T>(arr: T[]): T[] {
  const out = [...arr];
  for (let i = out.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [out[i], out[j]] = [out[j], out[i]];
  }
  return out;
}

let rawImages: ImageEntry[];

if (folder) {
  rawImages = listImagesInDir(pathMod.join(galleryBase, folder), folder);
  rawImages.sort((a, b) => a.name.localeCompare(b.name));
} else {
  const subfolders = ["geometric", "realism", "blackwork"] as const;
  rawImages = subfolders.flatMap((sub) =>
    listImagesInDir(pathMod.join(galleryBase, sub), sub),
  );
  rawImages = shuffle(rawImages).slice(0, 21);
}

const pieces = rawImages.map((entry, index) => ({
  id: `img-${index + 1}`,
  src: `/images/gallery/${entry.subfolder}/${entry.name}`,
  title: `Tatouage clm.ink #${index + 1}`,
}));

const PER_SLIDE = 3;
const PER_PAGE_THEME = 20;

const groups: (typeof pieces)[] = [];
const themePageGroups: (typeof pieces)[] = [];

if (folder) {
  for (let i = 0; i < pieces.length; i += PER_PAGE_THEME) {
    themePageGroups.push(pieces.slice(i, i + PER_PAGE_THEME));
  }
} else {
  for (let i = 0; i < pieces.length; i += PER_SLIDE) {
    groups.push(pieces.slice(i, i + PER_SLIDE));
  }
}

const totalThemePages = themePageGroups.length;
---

<section id="work" class="bg-black">
  <div class="container-narrow pt-8 sm:pt-12 pb-8 sm:pb-10 space-y-6">
    {
      !hideHeader && (
        <header class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4">
          <div>
            <p class="text-xs uppercase tracking-[0.35em] text-neutral-500">
              {kicker}
            </p>
            <h2 class="mt-2 text-2xl sm:text-3xl font-semibold tracking-tight">
              {title}
            </h2>
          </div>
          <p class="text-sm text-neutral-400 max-w-md">{description}</p>
        </header>
      )
    }

    {
      folder ? (
        <div
          class="gallery-pagination-wrapper -mx-4 sm:-mx-6 lg:-mx-8 w-[calc(100%+2rem)] sm:w-[calc(100%+3rem)] lg:w-[calc(100%+4rem)]"
          data-total-pages={totalThemePages}
        >
          {themePageGroups.map((pagePieces, pageIndex) => (
            <div
              class={`gallery-page ${pageIndex === 0 ? "block" : "hidden"}`}
              data-page={pageIndex}
            >
              <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-5 w-full">
                {pagePieces.map((piece) => (
                  <button
                    type="button"
                    data-gallery-image
                    class="group relative w-full overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/80 focus:outline-none focus:ring-2 focus:ring-neutral-400/60"
                  >
                    <div class="aspect-[4/5] w-full bg-neutral-900">
                      <img
                        src={piece.src}
                        alt={piece.title}
                        loading="lazy"
                        decoding="async"
                        class="h-full w-full object-cover filter grayscale group-hover:grayscale-0 transition duration-500"
                      />
                    </div>
                  </button>
                ))}
              </div>
            </div>
          ))}
          {totalThemePages > 1 && (
            <nav
              class="mt-8 flex items-center justify-center gap-4"
              aria-label="Pagination galerie"
            >
              <button
                type="button"
                class="gallery-pagination-prev inline-flex items-center justify-center rounded-full border border-neutral-600 bg-black/60 px-4 py-2 text-xs uppercase tracking-wider text-neutral-300 hover:border-neutral-200 hover:text-neutral-100 disabled:opacity-40 disabled:pointer-events-none transition-colors"
                aria-label="Page précédente"
              >
                ‹ Précédent
              </button>
              <span class="gallery-pagination-info text-xs text-neutral-500 min-w-[6rem] text-center">
                Page{" "}
                <span class="gallery-pagination-current font-medium text-neutral-300">
                  1
                </span>{" "}
                /{" "}
                <span class="gallery-pagination-total">{totalThemePages}</span>
              </span>
              <button
                type="button"
                class="gallery-pagination-next inline-flex items-center justify-center rounded-full border border-neutral-600 bg-black/60 px-4 py-2 text-xs uppercase tracking-wider text-neutral-300 hover:border-neutral-200 hover:text-neutral-100 disabled:opacity-40 disabled:pointer-events-none transition-colors"
                aria-label="Page suivante"
              >
                Suivant ›
              </button>
            </nav>
          )}
        </div>
      ) : (
        <div
          class="relative gallery-slider-wrapper -mx-4 sm:-mx-6 lg:-mx-8 w-[calc(100%+2rem)] sm:w-[calc(100%+3rem)] lg:w-[calc(100%+4rem)]"
          data-auto-play={autoPlay ? "true" : "false"}
        >
          <button
            type="button"
            class="gallery-prev max-sm:hidden inline-flex h-9 w-9 items-center justify-center rounded-full border border-neutral-600 bg-black/40 text-sm text-neutral-100 hover:border-neutral-200 hover:bg-neutral-800/90 hover:text-neutral-50 transition-colors absolute left-2 top-1/2 -translate-y-1/2 z-10"
            aria-label="Pièces précédentes"
          >
            ‹
          </button>
          <button
            type="button"
            class="gallery-next max-sm:hidden inline-flex h-9 w-9 items-center justify-center rounded-full border border-neutral-600 bg-black/40 text-sm text-neutral-100 hover:border-neutral-200 hover:bg-neutral-800/90 hover:text-neutral-50 transition-colors absolute right-2 top-1/2 -translate-y-1/2 z-10"
            aria-label="Pièces suivantes"
          >
            ›
          </button>

          <div class="overflow-hidden">
            <div
              class={`gallery-track flex transition-transform ease-out ${autoPlay ? "duration-700" : "duration-500"}`}
              data-page-count={groups.length}
            >
              {groups.map((group, index) => (
                <div
                  class="min-w-full grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-5 w-full"
                  data-page={index}
                >
                  {group.map((piece, pieceIndex) => (
                    <button
                      type="button"
                      data-gallery-image
                      class={
                        "group relative w-full overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/80 focus:outline-none focus:ring-2 focus:ring-neutral-400/60" +
                        (pieceIndex > 0 ? " hidden sm:block" : "")
                      }
                    >
                      <div class="aspect-[4/5] w-full bg-neutral-900">
                        <img
                          src={piece.src}
                          alt={piece.title}
                          loading="lazy"
                          decoding="async"
                          class="h-full w-full object-cover filter grayscale group-hover:grayscale-0 transition duration-500"
                        />
                      </div>
                    </button>
                  ))}
                </div>
              ))}
            </div>
          </div>
        </div>
      )
    }

    {
      !folder && (
        <div class="space-y-6">
          <div class="space-y-1">
            <p class="text-xs uppercase tracking-[0.35em] text-neutral-500">
              Explorer par style
            </p>
            <p class="text-sm text-neutral-400 max-w-2xl">
              Sélection de pièces classées par univers : géométrique, réalisme
              noir et gris ou blackwork graphique.
            </p>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-6 text-sm">
            <a
              href="/geometric"
              class="group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/60 px-5 py-4 flex flex-col gap-2 hover:border-neutral-200 hover:bg-neutral-900/80 transition-colors"
            >
              <div
                class="pointer-events-none absolute inset-0 opacity-[0.15] group-hover:opacity-[0.25] transition-opacity"
                aria-hidden="true"
              >
                <img
                  src="/geometric.png"
                  alt=""
                  loading="lazy"
                  class="h-full w-full object-cover grayscale scale-150 -translate-x-4"
                />
              </div>
              <div class="relative">
                <h3 class="text-sm font-medium text-neutral-50">Geometric</h3>
                <p class="text-xs text-neutral-300">
                  Lignes fines, mandalas, motifs abstraits et compositions
                  graphiques en noir et gris.
                </p>
              </div>
            </a>
            <a
              href="/realism"
              class="group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/60 px-5 py-4 flex flex-col gap-2 hover:border-neutral-200 hover:bg-neutral-900/80 transition-colors"
            >
              <div
                class="pointer-events-none absolute inset-0 opacity-[0.15] group-hover:opacity-[0.25] transition-opacity"
                aria-hidden="true"
              >
                <img
                  src="/realism.png"
                  alt=""
                  loading="lazy"
                  class="h-full w-full object-cover grayscale scale-150 translate-x-6"
                />
              </div>
              <div class="relative">
                <h3 class="text-sm font-medium text-neutral-50">Realism</h3>
                <p class="text-xs text-neutral-300">
                  Portraits, animaux et pièces réalistes en noir et gris,
                  centrés sur les contrastes.
                </p>
              </div>
            </a>
            <a
              href="/blackwork"
              class="group relative overflow-hidden rounded-2xl border border-neutral-800 bg-neutral-950/60 px-5 py-4 flex flex-col gap-2 hover:border-neutral-200 hover:bg-neutral-900/80 transition-colors"
            >
              <div
                class="pointer-events-none absolute inset-0 opacity-[0.15] group-hover:opacity-[0.25] transition-opacity"
                aria-hidden="true"
              >
                <img
                  src="/blackwork.png"
                  alt=""
                  loading="lazy"
                  class="h-full w-full object-cover grayscale scale-150"
                />
              </div>
              <div class="relative">
                <h3 class="text-sm font-medium text-neutral-50">Blackwork</h3>
                <p class="text-xs text-neutral-300">
                  Aplats noirs, textures et compositions fortes pour des projets
                  graphiques impactants.
                </p>
              </div>
            </a>
          </div>
        </div>
      )
    }
  </div>
</section>

<div
  id="gallery-modal"
  class="fixed inset-0 z-50 hidden items-center justify-center bg-black/80 px-4"
>
  <button
    type="button"
    class="absolute inset-0 w-full h-full cursor-default"
    data-gallery-close
    aria-label="Fermer l'image"></button>
  <div
    class="relative max-w-3xl w-full max-h-[90vh] flex flex-col items-center"
  >
    <div
      class="relative w-max max-w-full max-h-[85vh] rounded-2xl border border-neutral-800 bg-neutral-950/80 overflow-hidden"
    >
      <button
        type="button"
        class="absolute top-2 right-2 z-10 inline-flex h-8 w-8 items-center justify-center rounded-full border border-neutral-600 text-xs text-neutral-200 hover:border-neutral-300 hover:text-neutral-50 bg-black/60"
        data-gallery-close
        aria-label="Fermer"
      >
        ✕
      </button>
      <img
        id="gallery-modal-image"
        src=""
        alt=""
        loading="lazy"
        class="max-h-[85vh] max-w-full w-auto h-auto object-contain block"
      />
    </div>
  </div>
</div>
