---
---

<section id="top" class="border-b border-neutral-900 bg-gradient-to-b from-black via-black to-neutral-950">
  <div class="container-narrow py-16 sm:py-24 lg:py-28 grid gap-10 lg:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)] items-center">
    <div class="space-y-6">
      <p class="text-xs uppercase tracking-[0.35em] text-neutral-500">
        Tattoo artist — Chambéry, France
      </p>
      <h1 class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight">
        Geometric.<br />
        Realist.<br />
        Blackwork.
      </h1>
      <p class="text-sm sm:text-base text-neutral-300 max-w-xl">
        clm.ink est un tatoueur basé à Chambéry, spécialisé dans les lignes géométriques
        précises, le réalisme en noir et gris et les pièces blackwork graphiques.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 sm:items-center">
        <a
          href="#contact"
          class="inline-flex items-center justify-center rounded-full border border-neutral-100 bg-neutral-100 px-6 py-2.5 text-xs font-medium uppercase tracking-[0.25em] text-black hover:bg-white transition-colors"
        >
          Prendre contact
        </a>
        <a
          href="#work"
          class="inline-flex items-center justify-center rounded-full border border-neutral-800 px-6 py-2.5 text-xs font-medium uppercase tracking-[0.25em] text-neutral-300 hover:border-neutral-200 hover:text-neutral-100 transition-colors"
        >
          Voir les pièces
        </a>
      </div>
      <div class="flex flex-wrap gap-4 text-xs text-neutral-500">
        <span class="inline-flex items-center gap-2">
          <span class="h-[1px] w-6 bg-neutral-700" />
          Chambéry — France
        </span>
        <span class="inline-flex items-center gap-2">
          <span class="h-[1px] w-6 bg-neutral-700" />
          Sponsor officiel
          <a
            href="https://www.instagram.com/hand_ink_"
            target="_blank"
            rel="noreferrer"
            class="underline underline-offset-4 decoration-neutral-500 hover:decoration-neutral-200"
          >
            @hand_ink_
          </a>
        </span>
      </div>
    </div>

    <div class="relative">
      <div class="aspect-[3/4] w-full max-w-sm mx-auto rounded-3xl border border-neutral-800 bg-neutral-950/60 overflow-hidden shadow-[0_0_80px_rgba(0,0,0,0.9)]">
        <div class="h-full w-full bg-[radial-gradient(circle_at_top,_#27272a,_#020617)]" />
        <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0,rgba(250,250,250,0.12),transparent_55%),radial-gradient(circle_at_80%_100%,rgba(250,250,250,0.08),transparent_55%)] mix-blend-screen" />
      </div>
      <div class="absolute -bottom-6 left-1/2 -translate-x-1/2 rounded-full border border-neutral-800 bg-black/80 backdrop-blur px-4 py-2 text-[11px] uppercase tracking-[0.25em] text-neutral-300 flex items-center gap-3">
        <span class="h-1.5 w-1.5 rounded-full bg-neutral-100" />
        clm.ink
        <span class="text-neutral-500">Since 2024</span>
      </div>
    </div>
  </div>
</section>

