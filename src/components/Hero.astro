---

---

<section
  id="top"
  class="border-b border-neutral-900 bg-gradient-to-b from-black via-black to-neutral-950"
>
  <div
    class="container-narrow py-10 sm:py-14 lg:py-16 grid gap-10 lg:grid-cols-[minmax(0,1.3fr)_minmax(0,1fr)] items-center"
  >
    <div class="relative">
      <div
        id="hero-left"
        class="relative space-y-6 max-w-xl mx-auto lg:mx-0 overflow-hidden"
      >
        <div class="relative space-y-6">
          <p
            class="text-xs uppercase tracking-[0.35em] text-neutral-500 flex items-center gap-2"
          >
            Tattoo artist — Chambéry, France
          </p>
          <h1
            class="text-4xl sm:text-5xl lg:text-6xl font-semibold tracking-tight"
          >
            Geometric.<br />
            Realist.<br />
            Blackwork.
          </h1>
          <p class="text-sm sm:text-base text-neutral-300">
            clm.ink est un tatoueur basé à Chambéry, spécialisé dans les lignes
            géométriques précises, le réalisme en noir et gris et les pièces
            blackwork graphiques, pour des projets sur-mesure pensés avec vous.
          </p>
          <div class="flex flex-col sm:flex-row gap-3 sm:items-center">
            <a
              href="#contact"
              class="inline-flex items-center justify-center rounded-full border border-neutral-100 bg-neutral-100 px-6 py-2.5 text-xs font-medium uppercase tracking-[0.25em] text-black hover:bg-white transition-colors"
            >
              Prendre contact
            </a>
            <a
              href="#work"
              class="inline-flex items-center justify-center rounded-full border border-neutral-800 px-6 py-2.5 text-xs font-medium uppercase tracking-[0.25em] text-neutral-300 hover:border-neutral-200 hover:text-neutral-100 transition-colors"
            >
              Voir les pièces
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="relative">
      <div
        class="aspect-[3/4] w-full max-w-sm mx-auto rounded-3xl border border-neutral-800 bg-neutral-950/60 overflow-hidden shadow-[0_0_80px_rgba(0,0,0,0.9)]"
      >
        <img
          src="/images/splash.jpeg"
          alt="Tatouage en cours par clm.ink"
          loading="eager"
          fetchpriority="high"
          class="h-full w-full object-cover filter grayscale"
        />
        <div
          class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_20%_0,rgba(250,250,250,0.16),transparent_55%),radial-gradient(circle_at_80%_100%,rgba(0,0,0,0.6),transparent_55%)] mix-blend-soft-light"
        >
        </div>
      </div>
    </div>
  </div>
</section>
